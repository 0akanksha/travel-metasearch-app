# Database (Neon serverless Postgres)
DATABASE_URL=

# Auth
JWT_SECRET=

PORT=4000
NODE_ENV=development

# Seeds an initial admin user on first run (no public signup — traveler
# booking and price alerts are both guest-only, admin is seeded this way)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Flight search + booking (duffel.com test token) — the only flight/booking
# data source; payment is Duffel's simulated test-mode balance, not Stripe.
DUFFEL_API_KEY=

# Price-alert emails (resend.com). Without a domain verified in Resend, the
# shared onboarding@resend.dev sender only delivers to the email address the
# Resend account itself was signed up with.
RESEND_API_KEY=

# Base URL used to build the "manage/unsubscribe" links inside alert emails.
# Defaults to http://localhost:4000 in code if unset — override for prod.
APP_BASE_URL=

# RapidAPI account key (rapidapi.com), shared across two subscriptions:
# - "Hotels.com Provider" listing — real hotel search/pricing data. No
#   booking-creation endpoint exists on it, so hotel bookings are recorded
#   locally, not with them.
# - "Forward & Reverse Geocoding" listing — real address geocoding for cab
#   pickup/drop-off search. Swapped in for public Nominatim, which returns
#   429s from Render's shared IP in production (see server/src/lib/routing.ts).
RAPIDAPI_KEY=

# Cab driving distance/duration needs no API key — OSRM's public demo
# routing server is free and keyless. See server/src/lib/routing.ts.

# 24/7 support chatbot — Groq's hosted inference (console.groq.com), free
# tier, no local server needed. Sign up, create an API key, and paste it
# below. GROQ_MODEL is optional (defaults to llama-3.3-70b-versatile in code).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
