# Database (Neon serverless Postgres)
DATABASE_URL=

# Auth
JWT_SECRET=

PORT=4000
NODE_ENV=development

# Seeds an initial admin user on first run (no public signup — traveler
# booking and price alerts are both guest-only, admin is seeded this way)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Flight search + booking (duffel.com test token) — the only flight/booking
# data source; payment is Duffel's simulated test-mode balance, not Stripe.
DUFFEL_API_KEY=

# Price-alert emails (resend.com). Without a domain verified in Resend, the
# shared onboarding@resend.dev sender only delivers to the email address the
# Resend account itself was signed up with.
RESEND_API_KEY=

# Base URL used to build the "manage/unsubscribe" links inside alert emails.
# Defaults to http://localhost:4000 in code if unset — override for prod.
APP_BASE_URL=

# Hotel search (rapidapi.com "Hotels.com Provider" listing, free tier) — real
# hotel search/pricing data. No booking-creation endpoint exists on this
# unofficial listing, so hotel bookings are recorded locally, not with them.
RAPIDAPI_KEY=

# Cab fare estimates need no API key — geocoding (Nominatim) and driving
# routes (OSRM's public demo server) are both free, keyless public services.
# See server/src/lib/routing.ts.
